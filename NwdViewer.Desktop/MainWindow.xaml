<Window x:Class="NwdViewer.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:vm="clr-namespace:NwdViewer.Desktop.ViewModels"
        Title="3D Model Viewer — NWD · NWC · FBX · IFC · glTF · OBJ · STL"
        Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        KeyDown="OnWindowKeyDown">
    <Window.Resources>
        <Style x:Key="TabHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="CornerRadius" Value="4,4,0,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="#FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#7AB3FF"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open .NWD / .NWC (via APS)..." Click="OnOpenApsFile"/>
                <MenuItem Header="Open _Open Format (IFC, glTF, OBJ, FBX, STL)..." Click="OnOpenOfflineFile"/>
                <Separator/>
                <MenuItem Header="_Save Image As..." Click="OnSaveImage" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Export to _PDF..."   Click="OnExportPdf"   InputGestureText="Ctrl+P"/>
                <Separator/>
                <MenuItem Header="_Close Active Tab" Click="OnCloseActiveTab"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="OnExit"/>
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="APS _Credentials..." Click="OnConfigureCredentials"/>
                <Separator/>
                <MenuItem x:Name="DarkModeItem" Header="_Dark Mode" IsCheckable="True" Click="OnToggleDarkMode"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_User Guide..." Click="OnShowHelp" InputGestureText="F1"/>
                <MenuItem Header="Open _Log Folder" Click="OnOpenLogFolder"/>
                <Separator/>
                <MenuItem Header="_About..." Click="OnShowAbout"/>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem><TextBlock Text="{Binding StatusText}"/></StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar Width="200" Height="14" Minimum="0" Maximum="100"
                             Value="{Binding ProgressPercent}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="360" MinWidth="220"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <Border DockPanel.Dock="Top" Background="#F4F4F4" BorderBrush="#CCC" BorderThickness="0,0,0,1" Padding="4,4,4,0">
                    <ItemsControl ItemsSource="{Binding Tabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource TabHeaderStyle}" MouseLeftButtonDown="OnTabClick" Cursor="Hand" Tag="{Binding}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                                        <Button Content="×" Click="OnCloseTabButton" Tag="{Binding}" Margin="8,0,0,0"
                                                Padding="4,0" FontWeight="Bold" BorderThickness="0"
                                                Background="Transparent" Foreground="#888" Cursor="Hand"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <wv2:WebView2 x:Name="Viewer"/>
            </DockPanel>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#DDD"/>

            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="Properties" FontWeight="Bold" Margin="8"/>
                <TreeView ItemsSource="{Binding ActiveTab.Properties}">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type vm:PropertyNode}" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Key}" FontWeight="SemiBold"/>
                                <TextBlock Text=": " Foreground="Gray"/>
                                <TextBlock Text="{Binding Value}"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
